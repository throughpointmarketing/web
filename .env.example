# Get your API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# For testing before domain verification:
SIGNAL_SCAN_FROM_EMAIL=ThroughPoint Marketing <onboarding@resend.dev>

# After verifying throughpointmarketing.com in Resend:
# SIGNAL_SCAN_FROM_EMAIL=ThroughPoint Marketing <notifications@throughpointmarketing.com>

# Google Search Console HTML tag verification (content value only, not the full meta tag)
GOOGLE_SITE_VERIFICATION=your_google_verification_code

# Google Tag Manager container ID (optional override; defaults to GTM-W3XRCSST in code)
NEXT_PUBLIC_GTM_ID=GTM-W3XRCSST

# Google Analytics 4 is configured inside GTM — add a GA4 Configuration tag there.
# No separate env var is required unless you later choose direct gtag installation.
